/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include <nordic/nrf52840_partition.dtsi>
#include <dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/led/led.h>
#include "vr_trackers-pinctrl.dtsi"


/ {
    model = "Ellie VR Trackers";
    compatible = "ellie,vr-trackers";

    chosen {
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
        zephyr,code-partition = &slot0_partition;
        zephyr,ieee802154 = &ieee802154;
    };

    buttons {
        compatible = "gpio-keys";
        button0: button_0 {
            /* Schematic SW2 -> P1.09 */
            gpios = <&gpio1 9 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
            label = "Push button";
            zephyr,code = <INPUT_KEY_0>;
        };
    };

    charger {
        compatible = "gpio-keys"; 
        charger_stat: charger_stat {
            gpios = <&gpio0 12 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
            label = "Charger Status";
        };
    };

    aliases {
        sw0 = &button0;
        watchdog0 = &wdt0;
        accel0 = &lsm6dsv;
        magn0 = &bmm350;
        fuel-gauge0 = &max17048;
        charger-stat = &charger_stat;
        led-strip = &led_strip;
    };
};

&reg0 { status = "okay"; };
&reg1 {
    regulator-initial-mode = <NRF5X_REG_MODE_DCDC>;
    status = "okay";
};
&gpiote { status = "okay"; };
&gpio0 { status = "okay"; };
&gpio1 { status = "okay"; };

&i2c0 {
    compatible = "nordic,nrf-twim";
    status = "okay";
    pinctrl-0 = <&i2c0_default>;
    pinctrl-1 = <&i2c0_sleep>;
    pinctrl-names = "default", "sleep";
    clock-frequency = <I2C_BITRATE_FAST>;

    bmm350: bmm350@14 {
        compatible = "bosch,bmm350";
        reg = <0x14>;
        drdy-gpios = <&gpio1 4 GPIO_ACTIVE_HIGH>;
        status = "okay";
        odr = "100"; // can go up to 400hz
        osr = <2>;   /* Oversampling: 1, 2, 4, or 8 */
    };

    max17048: max17048@36 {
        compatible = "maxim,max17048";
        reg = <0x36>;
        status = "okay";
    };
};

&spi1 {
    compatible = "nordic,nrf-spi";
    status = "okay";
    pinctrl-0 = <&spi1_default>;
    pinctrl-1 = <&spi1_sleep>;
    pinctrl-names = "default", "sleep";

    cs-gpios = <&gpio1 1 GPIO_ACTIVE_LOW>;

    lsm6dsv: lsm6dsv@0 {
        compatible = "st,lsm6dsv16x";
        reg = <0>;
        spi-max-frequency = <8000000>;
        int1-gpios = <&gpio0 20 GPIO_ACTIVE_HIGH>;
        int2-gpios = <&gpio0 17 GPIO_ACTIVE_HIGH>;
        status = "okay";
    };
};

&i2s0 {
    status = "okay";
    pinctrl-0 = <&i2s0_default>;
    pinctrl-1 = <&i2s0_sleep>;
    pinctrl-names = "default", "sleep";

    led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-i2s";
        
        reg = <0>;
        chain-length = <1>;
        color-mapping = <LED_COLOR_ID_GREEN
				 LED_COLOR_ID_RED
				 LED_COLOR_ID_BLUE>;

        reset-delay = <120>;
    };
};

&usbd {
    compatible = "nordic,nrf-usbd";
    status = "okay";

    hid_dev_0: hid_dev_0 {
        compatible = "zephyr,hid-device";
		label = "HID0";
		protocol-code = "none";
		in-polling-period-us = <1000>;
		in-report-size = <64>;
    };
};
